# Server
PORT=4000
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# M-Pesa Daraja
DARAJA_CONSUMER_KEY=your-daraja-consumer-key
DARAJA_CONSUMER_SECRET=your-daraja-consumer-secret
DARAJA_SHORTCODE=174379
DARAJA_PASSKEY=your-passkey
DARAJA_CALLBACK_URL=https://inua-empowerment-hub.vercel.app/api/payments/callback

# Email provider configuration
EMAIL_FROM=noreply@smacom.co.ke
EMAIL_PROVIDER=sendgrid # or smtp
SENDGRID_API_KEY=
# SMTP_HOST=smtp.yourprovider.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASSWORD=your-smtp-password
